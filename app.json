{
  "expo": {
    "name": "Zcare",
    "slug": "zcare",
    "version": "1.0.1",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.zcare.auth",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "zcare.duckdns.org": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.zcare.auth",
      "versionCode": 2,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store"
    ]
  }
}
