{
  "expo": {
    "name": "Zcare",
    "slug": "zcare",
    "version": "1.0.0",
    "ios": {
      "bundleIdentifier": "com.zcare.auth", 
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store"
    ]
  }
}
