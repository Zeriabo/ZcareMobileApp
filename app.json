{
  "expo": {
    "name": "Zcare",
    "slug": "zcare",
    "version": "1.0.0",
    "ios": {
      "bundleIdentifier": "com.zcare.auth",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "zcare.duckdns.org": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.zcare.auth",
      "versionCode": 1,
      "usesCleartextTraffic": true
    },
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store"
    ]
  }
}
