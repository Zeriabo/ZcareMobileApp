# Environment Variables Template
# Copy this file to .env and fill in actual values
# DO NOT commit actual .env file to git

# API Configuration
EXPO_PUBLIC_BASE_URL=http://localhost:8080
EXPO_PUBLIC_SERVER_URL=http://localhost:8080
EXPO_PUBLIC_SOCKET_PORT=9099

# Third-party API Keys
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Optional: Override media base URL if backend serves media from different service
# EXPO_PUBLIC_MEDIA_BASE_URL=http://localhost:8080

# Optional: AI Service URL (for AI Assistant feature)
# EXPO_PUBLIC_AI_URL=http://localhost:5000
